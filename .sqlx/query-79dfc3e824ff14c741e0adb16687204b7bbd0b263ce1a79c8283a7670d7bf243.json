  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            sequence,\n            timestamp,\n            type,\n            stream,\n            visibility,\n            message,\n            data AS \"data: SqlxJson<Value>\"\n        FROM job_events\n        WHERE job_id = $1\n          AND sequence > $2\n        ORDER BY sequence ASC\n        LIMIT $3\n        ",
